{
  "name": "context-library",
  "version": "0.7.1",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && npm run copy-migrations",
    "copy-migrations": "cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "extract-entities": "tsx scripts/extract-entities.ts",
    "compact-history": "tsx scripts/compact-history.ts"
  },
  "dependencies": {
    "@hono/mcp": "^0.2.4",
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.4.7",
    "hono": "^4.12.8",
    "pg": "^8.20.0",
    "zod": "^3.25.0"
  },
  "overrides": {
    "path-to-regexp": "8.4.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@types/node": "^22.13.4",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
