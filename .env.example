# ── Tier 1: Core MCP Server ─────────────────────────────

# MCP server name (visible to LLM clients as the tool namespace)
SERVER_NAME=context-library
MCP_PORT=3100
NODE_ENV=production

# Data storage (use /app/data for Docker, ./data for local dev)
DATA_DIR=/app/data

# Comma-separated list of allowed origins. Default: https://claude.ai,https://claude.com
# CORS_ORIGINS=https://claude.ai,https://claude.com

# ── Tier 2: PostgreSQL (Tasks + FTS) ───────────────────

POSTGRES_DB=context_library
POSTGRES_USER=cl
# REQUIRED for Tier 2. Change this before deploying.
POSTGRES_PASSWORD=changeme

# For local dev (non-Docker), uncomment:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=cl
# PGPASSWORD=localdev
# PGDATABASE=context_library

# ── Tier 3: Embeddings (Semantic Search) ───────────────
#
# Embedding server profile — choose one when starting:
#   GPU:  docker compose -f docker-compose.yml -f docker-compose.postgres.yml -f docker-compose.embeddings.yml --profile embeddings-gpu up -d
#   CPU:  docker compose -f docker-compose.yml -f docker-compose.postgres.yml -f docker-compose.embeddings.yml --profile embeddings-cpu up -d
#
# With no --profile flag, neither TEI service starts (graceful degradation).
# Apple Silicon: run TEI natively via Homebrew and set EMBEDDING_URL to host.docker.internal.

EMBEDDING_URL=http://embeddings:80
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v2-moe
EMBEDDING_DIMENSIONS=768

# ── Reranker (optional, v0.6) ──────────────────────────
# Cross-encoder that rescores the top candidates from RRF fusion. Runs as a
# second TEI instance on port 8091 (see docker-compose.embeddings.yml).
# Start with:
#   GPU:  docker compose ... -f docker-compose.embeddings.yml --profile reranker-gpu up -d
#   CPU:  docker compose ... -f docker-compose.embeddings.yml --profile reranker-cpu up -d
# Leave unset or empty to disable — search_context falls back to RRF ordering.
# RERANKER_URL=http://reranker:80
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Search alias expansion (optional, v0.6) ────────────
# Deployment-local JSON file mapping abbreviations → expansion text. If the
# query contains an alias key as a whole word, the expansion is appended
# before the query is embedded. See search-aliases.example.json.
# SEARCH_ALIAS_PATH=./data/search-aliases.json

# ── Tier 4: Entity Extraction (docker-compose.entities.yml) ──
# Background extraction of entity triples from handoffs and notes into a
# knowledge graph (entity_nodes / entity_relations tables). Disabled by
# default. Extraction is fire-and-forget — if the provider is unreachable,
# writes still succeed and a warning is logged.
#
# Provider options:
#   ollama — local Ollama instance (set OLLAMA_BASE_URL)
#   api    — Anthropic/OpenAI-compatible API (set ENTITY_API_KEY)
#
# ENTITY_EXTRACTION_ENABLED=false
# ENTITY_EXTRACTION_PROVIDER=ollama
# ENTITY_EXTRACTION_ASYNC=true
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EXTRACTION_MODEL=sciphi/triplex
# ENTITY_MIN_CONFIDENCE=0.5
# ENTITY_EXTRACTION_TIMEOUT_MS=30000
# ENTITY_API_KEY=
# ENTITY_API_BASE_URL=https://api.anthropic.com
# ENTITY_API_MODEL=claude-sonnet-4-20250514
# ENTITY_API_FORMAT=anthropic

# ── Entity Graph Retrieval (optional, prompt 04) ──────
# When enabled, search_context recognizes named entities in the query, walks
# the entity_relations graph, and folds the resulting content IDs into RRF
# as a third ranking signal alongside vector and full-text. Disabled by
# default — turn on once an extraction run has populated entity_nodes.
# ENTITY_GRAPH_ENABLED=false
# ENTITY_GRAPH_HOPS=1                    # traversal depth, 1–3
# ENTITY_GRAPH_RRF_WEIGHT=0.3            # graph-signal weight in fusion (0–1)
# ENTITY_GRAPH_FTS_WEIGHT=1.0            # full-text weight (0–1)
# ENTITY_GRAPH_VECTOR_WEIGHT=1.0         # vector weight (0–1)
# ENTITY_GRAPH_MAX_CANDIDATES=50         # max content rows returned by traversal

# ── Auth Proxy (docker-compose.auth.yml) ───────────────
# Required only for exposing Context Library to the internet.
# Requires an OIDC provider (Auth0, Google, etc.)

# AUTH0_ISSUER=https://your-tenant.us.auth0.com/
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# ALLOWED_USERS=user@example.com
# EXTERNAL_URL=https://context-library.example.com

# Cloudflare Tunnel token for the named tunnel that routes to this deployment.
# Create a tunnel in the Cloudflare dashboard (Zero Trust → Networks → Tunnels),
# configure its public hostname to point to https://mcp-auth-proxy:443,
# then paste the tunnel token here. The cloudflared container reads this as
# TUNNEL_TOKEN directly, matching the variable name used by the image.
# TUNNEL_TOKEN=

# ── Observability ────────────────────────────────────────
# Structured response logs are emitted for every /mcp request at INFO level
# (one JSON line per response). They include tool name, JSON-RPC status,
# duration_ms, size_bytes, and a correlation_id. Response bodies are NOT
# logged by default — they may contain user-supplied content (handoff state,
# notes, search hits). Set the flag below to true to include the body for
# debugging. Use sparingly; logs may be retained longer than callers expect.
# LOG_RESPONSE_BODIES=false

# ── Sync HTTP endpoints (Phase 1a — mobile client foundation) ──
# Plain HTTP /sync/changes and /sync/push endpoints for clients that can't
# participate in the MCP OAuth flow (e.g. an iOS app). Auth is a pluggable
# bearer-token boundary — the repo commits the interface + a static-token
# reference implementation; deployments choose their own token value.
# When SYNC_BEARER_TOKEN is unset OR empty, /sync/* returns 401 for every
# request (opt-in surface). Deployments that want to wire their own auth
# (JWT, HMAC, mTLS lookup) should install a custom SyncAuthenticator at
# startup and can leave this variable unset.
# SYNC_BEARER_TOKEN=
# Optional tuning for GET /sync/changes:
# SYNC_CHANGES_DEFAULT_LIMIT=100          # rows per pull when limit omitted
# SYNC_CHANGES_MAX_LIMIT=500              # hard cap on the limit query param

# ── Notifications ────────────────────────────────────────
# Push notification URL for CI/CD pipeline events.
# Default: https://ntfy.sh/context-library-ci (public ntfy instance)
# For self-hosted: https://your-ntfy-server/your-topic
# Set as GitHub Actions secret NTFY_URL for private topics.
# NTFY_URL=https://ntfy.sh/context-library-ci
