# Authentication is handled by mcp-auth-proxy — see docker-compose.yml

# mcp-auth-proxy (handles OAuth 2.1: DCR, authorize, token, discovery)
AUTH0_ISSUER=https://your-tenant.us.auth0.com/
AUTH0_CLIENT_ID=<your MCP client app client ID>
AUTH0_CLIENT_SECRET=<your MCP client app client secret>
ALLOWED_USERS=user@example.com
EXTERNAL_URL=https://cb.example.com

# Server
# MCP server name (visible to LLM clients as the tool namespace)
SERVER_NAME=context-library
MCP_PORT=3100
NODE_ENV=production

# Data storage (use /app/data for Docker, ./data for local dev)
DATA_DIR=/app/data

# Postgres
POSTGRES_PASSWORD=
# For local dev (non-Docker):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=cb
# PGPASSWORD=localdev
# PGDATABASE=cognition_bridge

# Local Embedding Server (TEI)
EMBEDDING_URL=http://embeddings:80
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v2-moe
EMBEDDING_DIMENSIONS=768

# Cloudflare Tunnel
# Path to the directory containing your tunnel credentials JSON file
# Created by: cloudflared tunnel create cognition-bridge
CLOUDFLARED_CREDS_PATH=./.cloudflared

# Optional: if using token-based tunnel auth instead of credentials file
# TUNNEL_TOKEN=
